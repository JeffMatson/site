---
import TopNav from './TopNav.astro';

const { title = null, children = null, showTopNav = false } = Astro.props;
---

<div class="browserWindow">
    <div class="wrapper">
        <header class="header">
            <div class="title">{title}</div>
            {showTopNav ? <TopNav /> : null}
        </header>
        <div class="main">
            <slot />
        </div>
    </div>
</div>

<style>
	.browserWindow {
        box-shadow: var(--shadow-offset);
        background: var(--window-color-nav-background);
        border: 2px solid var(--window-color-border);
        padding: 3px;
        max-width: 920px;
        margin-left: auto;
        margin-right: auto;

        .wrapper {
            padding: 1px;
        }

        .header {
            font-family: var(--window-font-title);
            font-size: var(--font-size-sm);
        }

        .title {
            background-color: var(--window-color-background-left);
            color: var(--window-color-title-text);
            font-weight: bold;
            font-size: var(--font-size-sm);
            padding: 4px 3px;
            line-height: 1.2;
            background: linear-gradient(90deg, var(--window-color-background-left), var(--window-color-background-right));
            box-shadow: 0 1px 0 var(--window-color-nav-highlight), 0 2px 0 var(--window-color-nav-separator);
        }

        .main {
            background-color: var(--color-background);
            color: var(--color-text);
            font-family: var(--font-normal);
            letter-spacing: normal;
            box-shadow: var(--shadow-inset);
        }
    }
</style>