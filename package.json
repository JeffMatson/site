{
	"name": "@jeffmatson/site",
	"version": "0.0.1",
	"private": true,
	"packageManager": "pnpm@10.30.3",
	"type": "module",
	"scripts": {
		"dev": "pnpm generate-tokens && astro dev",
		"build": "pnpm generate-tokens && astro build",
		"generate-tokens": "tsx scripts/generate-tokens.ts",
		"optimize-fonts": "tsx scripts/optimize-fonts.ts",
		"preview": "astro preview",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:ui": "vitest --ui",
		"test:e2e": "playwright test",
		"test:screenshots": "playwright test test/e2e/screenshots.spec.ts",
		"lint": "biome check src/ scripts/ && prettier --check 'src/**/*.mdx'",
		"lint:fix": "biome check --write src/ scripts/ && prettier --write 'src/**/*.mdx'",
		"format": "biome format --write src/ scripts/ && prettier --write 'src/**/*.mdx'",
		"format:mdx": "prettier --write 'src/**/*.mdx'"
	},
	"dependencies": {
		"@astrojs/mdx": "^4.3.13",
		"@astrojs/react": "^4.4.2",
		"@astrojs/rss": "^4.0.15",
		"@astrojs/sitemap": "^3.7.0",
		"@nanostores/persistent": "^1.3.3",
		"@nanostores/react": "^1.0.0",
		"astro": "^5.18.0",
		"md5": "^2.3.0",
		"nanostores": "^1.1.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@fontsource/comic-neue": "^5.2.7",
		"@fontsource/tinos": "^5.2.7",
		"@fontsource/win95fa": "^5.2.5",
		"@playwright/test": "^1.58.2",
		"@testing-library/react": "^16.3.2",
		"@types/md5": "^2.3.6",
		"@types/node": "^25.3.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/ui": "^4.0.18",
		"happy-dom": "^20.8.3",
		"prettier": "^3.8.1",
		"sharp": "^0.34.5",
		"tsx": "^4.21.0",
		"ttf2woff2": "^8.0.1",
		"vitest": "^4.0.18"
	}
}
