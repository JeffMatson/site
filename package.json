{
  "name": "@jeffmatson/site",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "scripts": {
    "generate-tokens": "tsx scripts/generate-tokens.ts",
