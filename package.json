    "@nanostores/react": "^1.0.0",
    "@playwright/test": "^1.58.2",
    "@types/md5": "^2.3.6",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "astro": "^5.18.0",
    "happy-dom": "^20.7.0",
    "md5": "^2.3.0",
    "nanostores": "^1.1.1",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "dependencies": {
